generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  plan      String   @default("free") @db.VarChar(50)
  planId    String?  @map("plan_id") @db.Uuid
  status    String   @default("active") @db.VarChar(20)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  planRelation  Plan?          @relation(fields: [planId], references: [id])
  members       TenantMember[]
  subscriptions Subscription[]
  usageRecords  UsageRecord[]
  apiKeys       ApiKey[]
  contents      Content[]
  ttsRecords    TTSRecord[]
  accounts      Account[]
  publishRecords PublishRecord[]
  teamTasks     TeamTask[]
  teams         Team[]
  settingsObj   Setting[]
  auditLogs     AuditLog[]

  @@map("tenants")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  username       String   @unique @db.VarChar(100)
  email          String?  @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  name           String?  @db.VarChar(255)
  role           String   @default("user") @db.VarChar(20)
  status         String   @default("active") @db.VarChar(20)
  avatarUrl      String?  @map("avatar_url") @db.Text
  // API Keys stored encrypted (AES-256-GCM). Decrypt server-side before use.
  // Never return these fields in API responses. Use dedicated key-service for access.
  deepseekKey    String?  @map("deepseek_key") @db.Text
  seedanceApiKey String?  @map("seedance_api_key") @db.Text
  // Encryption key identifier — used for key rotation. 'v1' = AES-256-GCM with server secret.
  keyEncVersion  String?  @default("v1") @map("key_enc_version") @db.VarChar(10)
  walletAddress  String?  @unique @map("wallet_address") @db.VarChar(42)
  nftPass        Json     @default("[]") @map("nft_pass")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenantMembers TenantMember[]
  usageRecords  UsageRecord[]
  apiKeys       ApiKey[]
  contents      Content[]
  ttsRecords    TTSRecord[]
  teamTasks     TeamTask[]
  auditLogs     AuditLog[]
  accounts      Account[]
  operatorLogs  OperatorLog[]

  @@map("users")
}

model TenantMember {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("editor") @db.VarChar(50)
  status      String   @default("active") @db.VarChar(20)
  email       String?  @db.VarChar(255)
  inviteToken String?  @map("invite_token") @db.VarChar(255)
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_members")
}

model Subscription {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  plan                 String    @db.VarChar(50)
  planId               String?   @map("plan_id") @db.Uuid
  status               String    @default("active") @db.VarChar(20)
  currentPeriodStart   DateTime? @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz(6)
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id") @db.VarChar(255)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  planRel    Plan?  @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model UsageRecord {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  resourceType String   @map("resource_type") @db.VarChar(50)
  quantity     Int      @default(1)
  tokensUsed   Int?     @map("tokens_used")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, resourceType, createdAt])
  @@map("usage_records")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  name       String?   @db.VarChar(255)
  keyHash    String    @unique @map("key_hash") @db.VarChar(255)
  prefix     String?   @db.VarChar(8)
  scopes     String[]  @default([])
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@map("api_keys")
}

model Content {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  type      String   @default("text") @db.VarChar(50)          // text | tts | video
  title     String?  @db.VarChar(500)
  body      String?  @db.Text                                   // 正文
  platform  String?  @db.VarChar(50)                            // twitter/instagram/xiaohongshu/linkedin/facebook/tiktok/poster
  style     String?  @db.VarChar(50)                            // professional/casual/humorous/inspirational/technical/minimal
  status    String   @default("draft") @db.VarChar(20)          // draft | published
  tags      String[] @default([])                               // PostgreSQL array
  language  String?  @db.VarChar(20)                            // zh-CN/en-US/etc
  mediaUrl  String?  @map("media_url") @db.Text                 // image/video/audio URL
  metadata  Json     @default("{}")                             // extra fields
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, type])
  @@index([tenantId, platform])
  @@index([tenantId, status])
  @@map("contents")
}

model TTSRecord {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  text           String   @db.Text
  translatedText String?  @map("translated_text") @db.Text
  language       String   @default("zh-CN") @db.VarChar(20)
  voice          String   @db.VarChar(100)
  speed          String   @default("+0%") @db.VarChar(10)
  audioPath      String   @map("audio_path") @db.VarChar(500)
  duration       Float?                                           // seconds
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@map("tts_records")
}

model Account {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  userId             String?   @map("user_id") @db.Uuid
  platform           String    @db.VarChar(50)                        // twitter/facebook/instagram/xiaohongshu/tiktok/linkedin
  name               String    @db.VarChar(255)                      // display name
  platformUserId     String?   @map("platform_user_id") @db.VarChar(255)
  screenName         String?   @map("screen_name") @db.VarChar(255)
  credentials        Json      @default("{}")                        // encrypted oauth tokens
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, platform])
  @@map("accounts")
}

model Team {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("teams")
}

model TeamTask {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@map("team_tasks")
}

model Setting {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  key      String @db.VarChar(255)
  value    Json   @default("{}")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@map("settings")
}

model PublishRecord {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  contentId  String?  @map("content_id") @db.Uuid
  accountId  String   @map("account_id") @db.VarChar(255)
  platform   String   @db.VarChar(50)
  screenName String?  @map("screen_name") @db.VarChar(255)
  text       String?  @db.VarChar(500)
  status     String   @default("published") @db.VarChar(20)
  result     Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@map("publish_records")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  event     String   @db.VarChar(100)
  details   Json     @default("{}")
  ip        String?  @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, event, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model OperatorLog {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @map("admin_id") @db.Uuid
  action    String   @db.VarChar(100)
  target    String?  @db.VarChar(255)
  detail    Json?    @default("{}")
  ip        String?  @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  admin     User     @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@map("operator_logs")
}

model Plan {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @unique @db.VarChar(50)
  displayName   String   @map("display_name") @db.VarChar(100)
  description   String?  @db.Text
  price         Int      @default(0)
  tokensPerMonth    Int   @default(0) @map("tokens_per_month")
  contentPerMonth   Int   @default(0) @map("content_per_month")
  ttsPerMonth       Int   @default(0) @map("tts_per_month")
  videoPerMonth     Int   @default(0) @map("video_per_month")
  isDefault     Boolean  @default(false) @map("is_default")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenants       Tenant[]
  subscriptions Subscription[]

  @@map("plans")
}
