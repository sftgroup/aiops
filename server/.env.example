# Aiops Server - Environment Configuration
# Copy this file to .env and fill in your values

# REQUIRED: JWT secret for auth tokens (change this!)
JWT_SECRET=change-this-to-a-random-string

# DeepSeek API (for AI text generation)
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_KEY=

# Twitter API (for OAuth 1.0a direct posting)
# Get your keys at: https://developer.twitter.com/
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=

# MPTurbo API (video generation)
MPTURBO_API=http://localhost:8080/api/v1

# AiToEarn MCP (multi-platform publishing)
AITO_EARN_MCP=http://localhost:8090/api
AITO_EARN_KEY=

# OAuth 2.0 Base URL (public-facing URL of this server)
# Used for OAuth callback redirects
OAUTH_BASE_URL=http://localhost:5288

# LibTV (AI image/video generation)
LIBTV_TOKEN=

# Media API Keys (for video source stock footage)
PEXELS_API_KEY=
PIXABAY_API_KEY=
